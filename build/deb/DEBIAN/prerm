#!/bin/bash
set -e

echo "Removing Helper Node..."

rm -f /usr/local/bin/helper-node
rm -f /usr/share/applications/helper-node.desktop
rm -f /usr/share/pixmaps/helper-node.png

if [ -f /opt/helper-node/helper-node.desktop ]; then
    xdg-desktop-menu uninstall /opt/helper-node/helper-node.desktop 2>/dev/null || true
fi
if command -v update-desktop-database &>/dev/null; then
    update-desktop-database /usr/share/applications 2>/dev/null || true
fi

# Remove diretório completamente para evitar conflitos em reinstalação
rm -rf /opt/helper-node

exit 0
